      <aliases enabled='yes' />
      <column caption='Total_Amount' datatype='real' name='[Calculation_0266414290497536]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([amount])' />
      </column>
      <column caption='Total_Orders' datatype='integer' name='[Calculation_0266414291046401]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([invoice_id])' />
      </column>
      <column caption='Flagged Orders' datatype='integer' name='[Calculation_0266414291304450]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [validation_status] = &quot;FLAGGED&quot; THEN [invoice_id] END)' />
      </column>
      <column caption='Flag Rate' datatype='real' name='[Calculation_0266414291709955]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD(IF [validation_status] = &apos;FLAGGED&apos; THEN [invoice_id] END)&#13;&#10;/&#13;&#10;COUNTD([invoice_id])' />
      </column>
      <column caption='Order Count' datatype='integer' name='[Calculation_0266414309330948]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([invoice_id])' />
      </column>
      <column caption='Risk Score' datatype='real' name='[Calculation_0266414320689158]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(&#13;&#10;COUNTD(IF [validation_status] = &quot;FLAGGED&quot; THEN [invoice_id] END)&#13;&#10;/&#13;&#10;COUNTD([invoice_id])&#13;&#10;) * 70&#13;&#10;&#13;&#10;+&#13;&#10;(&#13;&#10;AVG(&#13;&#10;CASE [max_severity]&#13;&#10;WHEN &quot;HIGH&quot; THEN 3&#13;&#10;WHEN &quot;MEDIUM&quot; THEN 2&#13;&#10;WHEN &quot;LOW&quot; THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;) / 3&#13;&#10;) * 30' />
      </column>
      <column caption='Month' datatype='datetime' name='[Calculation_0716114929664000]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[invoice_date])' />
      </column>
      <column caption='Latest Month' datatype='datetime' name='[Calculation_0716114930298881]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{ MAX(DATETRUNC(&apos;month&apos;,[invoice_date])) }' />
      </column>
      <column caption='Previous Month' datatype='datetime' name='[Calculation_0716114930446338]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEADD(&apos;month&apos;, -1, [Calculation_0716114930298881])' />
      </column>
      <column caption='Rank' datatype='integer' name='[Calculation_1453887097061376]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(AVG([composite_score]))'>
          <table-calc ordering-field='[federated.091yskk1uc7mxc170rsdq0xuq5rq].[vendor_name]' ordering-type='Field' />
        </calculation>
      </column>
      <column caption='N Vendors' datatype='boolean' name='[Calculation_1453887097217025]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1453887097061376] &lt;= [Parameters].[Parameter 2]'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
